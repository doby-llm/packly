<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application android:allowBackup="true" android:icon="@mipmap/ic_launcher" android:label="Packly" android:roundIcon="@mipmap/ic_launcher_round" android:supportsRtl="true" android:theme="@style/Theme.Packly">
        <receiver android:name=".notification.DeadlineReminderReceiver" android:exported="false" />
        <activity android:name=".MainActivity" android:exported="true" android:theme="@style/Theme.Packly">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
